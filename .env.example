# EmailJS - Đăng ký tại https://www.emailjs.com/
# 1. Tạo Email Service (Gmail, Outlook...)
# 2. Tạo Email Template với biến: {{title}}, {{name}}, {{time}}, {{message}}, {{email}}
# 3. Gửi form qua API /api/contact (không dùng key trên client trừ site key Turnstile)

NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
# Nếu EmailJS báo "strict mode" / "no Private Key" — lấy Private Key ở Dashboard → Account → API keys (không dùng NEXT_PUBLIC)
EMAILJS_PRIVATE_KEY=your_private_key

# Cloudflare Turnstile — https://dash.cloudflare.com/ → Turnstile
# Site key (widget): NEXT_PUBLIC_... | Secret (chỉ server, không public): TURNSTILE_SECRET_KEY
# Test keys (luôn pass): site 1x0000000000000000000000000000000AA, secret 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_site_key
TURNSTILE_SECRET_KEY=your_secret_key
